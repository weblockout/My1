import hashlib
import base64
import ecdsa
import struct

def varint_encode(n):
    if n < 0xfd: return struct.pack('<B', n)
    elif n <= 0xffff: return b'\xfd' + struct.pack('<H', n)
    return b'\xfe' + struct.pack('<I', n)

def sign_variant(private_key_hex, message, prefix, compressed=True):
    priv_key = bytes.fromhex(private_key_hex)
    sk = ecdsa.SigningKey.from_string(priv_key, curve=ecdsa.SECP256k1)
    prefix_bytes = prefix.encode('utf-8')
    message_bytes = message.encode('utf-8')
    
    # Стандартный формат сообщения Bitcoin
    full_msg = varint_encode(len(prefix_bytes)) + prefix_bytes + varint_encode(len(message_bytes)) + message_bytes
    msg_hash = hashlib.sha256(hashlib.sha256(full_msg).digest()).digest()
    
    base_header = 31 if compressed else 27
    
    results = []
    for i in range(2): # Пробуем recovery ID 0 и 1
        sig = sk.sign_digest_deterministic(msg_hash, hashfunc=hashlib.sha256, sigencode=ecdsa.util.sigencode_string_canonize)
        header = struct.pack('<B', base_header + i)
        final_sig = base64.b64encode(header + sig).decode('utf-8')
        results.append(final_sig)
    return results

