                                print(f"КОНТЕКСТ ДО:\n...{context_before}")
                                print(f"ВЫЗОВ: {call_code}")
                                print("-" * 40)
                except:
                    pass

if __name__ == "__main__":
    scan_scrypt_calls()
```

