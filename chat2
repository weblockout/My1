    auth_str = (login + password).encode('utf-8')
    h1_hex = hashlib.sha256(auth_str).hexdigest()
    
    print(f"[*] Hash1 Hex: {h1_hex}")

    # 2. Используем HEX-строку как Seed для BIP32 (64 байта ASCII)
    seed = h1_hex.encode('utf-8')
    
    # 3. Создаем мастер-ноду (стандартный HMAC-SHA512 с "Bitcoin seed")
    I = hmac.new(b"Bitcoin seed", seed, hashlib.sha512).digest()
    master_priv = I[:32]
    master_chain = I[32:]
    bip = BIP32(master_priv, master_chain)
    
    # 4. Деривация ключей
    # Индекс 0 - Encryption Key (твой c2f0...)
