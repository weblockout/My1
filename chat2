def get_zelid_private_key(login, password):
    # 1. Вычисляем Hash1 (SHA256 от склейки)
    auth_str = login + password
    hash1_hex = hashlib.sha256(auth_str.encode()).hexdigest()
    print(f"[*] Hash1: {hash1_hex}")

    # 2. Считаем Scrypt, используя Hash1_hex как ПАРОЛЬ
    # Соль: login + pepper
    salt = (login + PEPPER).encode()
    
    print(f"[*] Считаю Scrypt...")
    seed = hashlib.scrypt(
        password=hash1_hex.encode(), 
        salt=salt, 
        n=16384, r=8, p=1, dklen=64
    )
    
    # 3. Получаем промежуточный ключ (Encryption Key)
    c2f0_key = seed[:32].hex()
    print(f"[*] Промежуточный ключ (c2f0): {c2f0_key}")
    
    # 4. ФИНАЛЬНЫЙ ШАГ: SHA256 от HEX-строки промежуточного ключа
    final_priv_key = hashlib.sha256(c2f0_key.encode()).hexdigest()
    return final_priv_key

def sign_message(priv_key_hex, message):
    priv_key_bytes = bytes.fromhex(priv_key_hex)
    sk = ecdsa.SigningKey.from_string(priv_key_bytes, curve=ecdsa.SECP256k1)
    prefix = "Bitcoin Signed Message:\n"
    p_bytes = prefix.encode('utf-8')
    m_bytes = message.encode('utf-8')
    
    def varint(n):
        if n < 0xfd: return struct.pack('<B', n)
        return b'\xfd' + struct.pack('<H', n)

    full_msg = varint(len(p_bytes)) + p_bytes + varint(len(m_bytes)) + m_bytes
    msg_hash = hashlib.sha256(hashlib.sha256(full_msg).digest()).digest()
    
    # Используем recovery ID = 1 (заголовок 32), как мы выяснили ранее
    sig = sk.sign_digest_deterministic(msg_hash, hashfunc=hashlib.sha256, sigencode=ecdsa.util.sigencode_string_canonize)
    header = struct.pack('<B', 32) 
    return base64.b64encode(header + sig).decode('utf-8')

