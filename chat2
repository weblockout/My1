import hashlib
import base64
import ecdsa
import struct
import requests
import time

# --- ВВОДНЫЕ ДАННЫЕ ---
LOGIN = "buginot"
PASSWORD = "ScvDbn70@"
PEPPER = "#<&{S-:}&,"
ZELID_DISPLAY = "1QJcn3ZA3zHcJ6oy3PLZVaiKCneD6JBQbT"

def get_zelcore_priv_key(login, password):
    # 1. Готовим "пароль" для Scrypt (Double SHA256 в формате Hex)
    login_lower = login.lower()
    auth_str = login_lower + password
    hash1 = hashlib.sha256(auth_str.encode()).digest()
    hash2_hex = hashlib.sha256(hash1).hexdigest() # Это e4c3ea79...
    
    # 2. Готовим соль
    salt = (login_lower + PEPPER).encode()
    
    # 3. Считаем Scrypt (N=16384, r=8, p=1, dkLen=64)
    # Используем hash2_hex как строку байтов
    seed = hashlib.scrypt(
        password=hash2_hex.encode(), 
        salt=salt, 
        n=16384, r=8, p=1, dklen=64
    )
    
    # 4. Берем ВТОРЫЕ 32 байта
    priv_key = seed[32:64]
    return priv_key

def sign_message(priv_key_bytes, message):
    prefix = "Bitcoin Signed Message:\n"
    sk = ecdsa.SigningKey.from_string(priv_key_bytes, curve=ecdsa.SECP256k1)
    
    def varint(n):
        if n < 0xfd: return struct.pack('<B', n)
        return b'\xfd' + struct.pack('<H', n)

    p_bytes = prefix.encode('utf-8')
    m_bytes = message.encode('utf-8')
    full_msg = varint(len(p_bytes)) + p_bytes + varint(len(m_bytes)) + m_bytes
    msg_hash = hashlib.sha256(hashlib.sha256(full_msg).digest()).digest()
    
    # Подпись с i=1 (как мы выяснили экспериментально)
    sig = sk.sign_digest_deterministic(msg_hash, hashfunc=hashlib.sha256, sigencode=ecdsa.util.sigencode_string_canonize)
    header = struct.pack('<B', 31 + 1) # 31 + 1 = 32 (байт для i=1)
    return base64.b64encode(header + sig).decode('utf-8')

def run_full_auth():
    print(f"[*] Генерирую ключ для пользователя: {LOGIN}")
    priv_key = get_zelcore_priv_key(LOGIN, PASSWORD)
    print(f"[+] Приватный ключ вычислен: {priv_key.hex()}")
    
