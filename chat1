                        print(f"Параметр p: {p_val}")
                        print(f"Вход Scrypt: {input_p}")
                        print(f"Твой Private Key (HEX): {seed[:32].hex()}")
                        found = True
                        return
                    else:
                        print(f"Тест соль {s[:10]}... p={p_val} -> {addr[:10]}...")
                except: continue
    
    if not found:
