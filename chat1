def get_actual_private_key(username, password):
    """
    Доказанная формула для Legacy аккаунтов Zelcore:
    1. SHA256(u+p)
    2. Salt = SHA256(u)
    3. Scrypt(n=16384, r=8, p=1, len=64)
    """
    u_clean = username.lower().strip()
    first_hash = hashlib.sha256((u_clean + password).encode()).digest()
    salt = hashlib.sha256(u_clean.encode()).digest()
    
    kdf = Scrypt(salt=salt, length=64, n=16384, r=8, p=1)
    master_seed = kdf.derive(first_hash)
    return master_seed[:32] # Это Private Key твоего устройства

