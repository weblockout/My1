        ("Direct SHA256", master_key_v1),
        ("Scrypt Part 1", master_seed_v2[:32]),
        ("Scrypt Part 2", master_seed_v2[32:64])
    ]

    for name, key in candidates:
        for comp in [True, False]:
            addr = get_btc_addr(key, compressed=comp)
            print(f"Попытка {name} ({'сжат' if comp else 'нет'}): {addr}")
            
            if addr == TARGET_ID:
                print(f"\n[!!!] УСПЕХ! ВАЛИДНЫЙ КЛЮЧ НАЙДЕН [!!!]")
