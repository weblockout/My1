        # В некоторых версиях сам хеш в JSON - это результат Scrypt (первые 32 байта в hex)
        kdf_test = Scrypt(salt=U.encode(), length=64, n=16384, r=8, p=1)
        res = kdf_test.derive(P.encode())
        if res[:32].hex() == TARGET_HASH:
            print("[+] ФОРМУЛА ХЕША: Scrypt[:32]")
            auth_key = P # В этом случае для следующего шага используем пароль

    # 2. Теперь ищем FluxID, перебирая разные Соли
    # Это то, что Zelcore использует в качестве Salt для финального Scrypt
    salts = [
        U.encode(),
        (U + "zelcore").encode(),
        (U + "zelid").encode(),
        (U + ACC_ID).encode(),
        hashlib.sha256(U.encode()).digest()
    ]

    print("\nПоиск FluxID...")
    found = False
    for s in salts:
        for p_val in [1, 8]:
