def bitcoin_sign_message(message, priv_key_bytes):
    """Создает подпись стандарта Bitcoin Signed Message"""
    sk = SigningKey.from_string(priv_key_bytes, curve=SECP256k1)
    
    # Формируем сообщение с префиксом
