    # 1. Сначала ищем, как получается хеш из JSON (Auth Key)
    # Перебираем варианты нормализации и склейки
    variants = [
        P, 
        U + P, 
        P + U, 
        PEPPER + P + PEPPER,
        PEPPER + P + PEPPER + hashlib.sha256(PEPPER.encode()).hexdigest()
    ]
    
    auth_key = None
    for v in variants:
        h = hashlib.sha256(v.encode()).hexdigest()
