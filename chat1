    """Создает подпись стандарта Bitcoin Signed Message (байт 31 для сжатых ключей)"""
    sk = SigningKey.from_string(priv_key_bytes, curve=SECP256k1)
    
    def varint_encode(n):
        if n < 0xfd: return struct.pack('<B', n)
        return b'\xfd' + struct.pack('<H', n)

    prefix = b'\x18Bitcoin Signed Message:\n'
    msg_bytes = message.encode('utf-8')
    full_msg = varint_encode(len(prefix)) + prefix + varint_encode(len(msg_bytes)) + msg_bytes
    
    msg_hash = hashlib.sha256(hashlib.sha256(full_msg).digest()).digest()
    sig_raw = sk.sign_digest_deterministic(msg_hash, hashfunc=hashlib.sha256)
    
    # Байт 31 = Compressed Key + Recovery ID 0
    return base64.b64encode(struct.pack('<B', 31) + sig_raw).decode()

